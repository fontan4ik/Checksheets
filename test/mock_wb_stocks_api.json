  "usage": {
    "column_O": "Сумма quantity по ВСЕМ warehouseId (все FBO склады)",
    "column_Z": "quantity где warehouseName = 'Москва (Подольск 3)' (ФЕРОН МОСКВА)",
    "column_AA": "quantity где warehouseName содержит 'ул. Индустриальная' (ВОЛЬТМИР)",
    "column_AI": "quantity где warehouseName содержит 'г.Самара' (Ферон Самара)",
    "column_AJ": "quantity где warehouseName содержит 'Внуково' (Ферон Внуково)",
    "column_Q": "quantity где warehouseId = 1449484 (Коледино - warehouseId фильтр)"
  },
  "filter_logic": {
    "by_warehouseId": "if (item.warehouseId === 1449484) keep(item)",
    "by_warehouseName": "if (item.warehouseName.includes('Подольск')) keep(item)",
    "aggregate": "Суммировать quantity для одного supplierArticle по всем warehouseName/warehouseId"
  }
