{
  "api": "Wildberries Statistics API",
  "endpoint": "/api/v1/supplier/stocks",
  "method": "GET",
  "url": "https://statistics-api.wildberries.ru/api/v1/supplier/stocks?dateFrom=2019-06-20",
  "description": "Получение остатков FBO/FBW по ВСЕМ складам WB",
  "response_structure": {
    "type": "array",
    "item_fields": {
      "warehouseId": "число - ID склада WB",
      "warehouseName": "строка - название склада",
      "supplierArticle": "строка - артикул продавца",
      "nmId": "число - артикул WB (nmId)",
      "barcode": "строка - штрихкод",
      "quantity": "число - количество товара",
      "category": "объект - информация о категории (опционально)"
    }
  },
  "example_response": [
    {
